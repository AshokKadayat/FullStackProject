{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && ./mvnw clean install -DskipTests",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "java -jar backend/target/journalApp-0.0.1-SNAPSHOT.jar",
    "healthCheckPath": "/journal/public/Health-check",
    "healthCheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE"
  }
}
